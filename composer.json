{
    "name": "aljerom/simple-hydrator",
    "description": "Reflection-based array-to-object hydrator with snake_case to camelCase mapping",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "psr-4": {
            "Aljerom\\SimpleHydrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aljerom\\SimpleHydrator\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    }
}
